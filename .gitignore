# Terraform generated files and directories
.terraform/

# Provider lock file (consider commiting if consistent provider versions are critical)
.terraform.lock.hcl

# Terraform state files
*.tfstate
*.tfstate.*backup

# Terraform plan files
*.tfplan

# Sensitve variables files (if not managed seperatly)
.tfvars
.tfvars.json

# Crash log files
crash.log

# Local overrides
# Terraform override files
override.tf
override.tf.json

# Terraform CLI congiguration files
.terraformrc
terraform.rc

# Provider specific files (if any)
# For example, if you're using AWS, you might have:
# .aws/credentials